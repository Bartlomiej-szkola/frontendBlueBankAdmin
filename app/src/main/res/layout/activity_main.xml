<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="?attr/colorSurface">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="BlueBank Admin"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="?attr/colorPrimary"
        android:layout_marginBottom="32dp"/>

    <!-- Karta: Dodaj Klienta -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardAddClient"
        style="?attr/materialCardViewElevatedStyle"
        android:layout_width="match_parent"
        android:layout_height="100dp"
        android:layout_marginBottom="16dp"
        android:clickable="true"
        android:focusable="true">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Dodaj Nowego Klienta"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_gravity="center"/>
    </com.google.android.material.card.MaterialCardView>

    <!-- Karta: Zarządzaj Klientem -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardManageClient"
        style="?attr/materialCardViewElevatedStyle"
        android:layout_width="match_parent"
        android:layout_height="100dp"
        android:layout_marginBottom="16dp"
        android:clickable="true"
        android:focusable="true">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Zarządzaj Klientem"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_gravity="center"/>
    </com.google.android.material.card.MaterialCardView>

    <!-- Karta: Skanuj Kartę (Identyfikacja) -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardScanNfc"
        style="?attr/materialCardViewFilledStyle"
        app:cardBackgroundColor="?attr/colorSecondaryContainer"
        android:layout_width="match_parent"
        android:layout_height="100dp"
        android:clickable="true"
        android:focusable="true">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Zidentyfikuj po Karcie (NFC)"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="?attr/colorOnSecondaryContainer"
            android:layout_gravity="center"/>
    </com.google.android.material.card.MaterialCardView>

</LinearLayout>